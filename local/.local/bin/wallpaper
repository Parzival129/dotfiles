#!/bin/bash

# Directory
WALLPAPER_DIR="$HOME/pictures/wallpapers"

# 1. Select the filename using rofi
# We pipe the find loop DIRECTLY into rofi. 
# This preserves the '\0' special character needed for icons.
SELECTED=$(find "$WALLPAPER_DIR" -type f \( -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" -o -iname "*.webp" \) | sort | while read -r fullpath; do
    filename=$(basename "$fullpath")
    # syntax: Display Name + \0 (null) + icon + \x1f (separator) + path to image
    echo -en "$filename\0icon\x1f$fullpath\n"
done | rofi -dmenu -i -show-icons -p "Select Wallpaper")

# Stop if user cancelled
if [ -z "$SELECTED" ]; then
    exit 0
fi

# 2. Define the full path to the image
FILE="$WALLPAPER_DIR/$SELECTED"

# 3. Apply the wallpaper
awww img "$FILE" --transition-type grow --transition-pos 0.5,0.5 --transition-fps 60

# 4. Generate colors
wal -i "$FILE" -n -q -s

# 5. Reload Hyprland
hyprctl reload
